<Page x:Class="Vistas.Paginas.Contratos.Cocktail"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Vistas.Paginas.Contratos"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Cocktail">

    <Page.Resources>
        <BindingGroup x:Key="BindingGroup" />
    </Page.Resources>
    <Grid>
        <TextBox x:Name="nombreTextBox" Margin="300,159,300,265" Width="200" Height="25"
                 Text="{Binding Path=Nombre, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                 BindingGroup="{StaticResource BindingGroup}" />
        <TextBox x:Name="emailTextBox" Margin="10,40,10,10" Width="200" Height="25"
                 Text="{Binding Path=Email, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                 BindingGroup="{StaticResource BindingGroup}" />
        <Button x:Name="validarButton" Margin="350,298,350,122" Width="100" Height="30"
                Content="Validar" Click="validarButton_Click" />
    </Grid>
</Page>
